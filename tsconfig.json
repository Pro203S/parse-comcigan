{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "target": "ES6",
    "lib": [
      "ES6",
      "DOM"
    ],
    "moduleResolution": "node16",
    "module": "node16",
    "esModuleInterop": true,
    "declaration": true,
    "strict": true,
    "sourceMap": true,
    "types": [
      "node"
    ],
    "typeRoots": [
      "./src/types",
      "./node_modules/@types"
    ]
  },
  "exclude": [
    "./test.ts",
    "./dist/*/**"
  ]
}